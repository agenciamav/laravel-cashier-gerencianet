{
    "name": "agenciamav/laravel-cashier-gerencianet",
    "description": "An expressive, fluent interface to Gerencianet's subscription billing services.",
    "keywords": [
        "laravel",
        "gerencianet",
        "billing",
        "cashier"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Luciano Tonet",
            "email": "tonetlds@gmail.com"
        }
    ],
    "require": {
        "php": "^7.2",
        "gerencianet/gerencianet-sdk-php": "^2.4",
        "dompdf/dompdf": "^0.8.6",
        "illuminate/database": "^8.7",
        "illuminate/support": "^8.7",
        "moneyphp/money": "^3.3",
        "nesbot/carbon": "^2.40"
    },
    "autoload": {
        "psr-4": {
            "Agenciamav\\LaravelCashierGerencianet\\": "src/"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests/Traits/"
        ]
    },
    "require-dev": {
        "mockery/mockery": "^1.4",
        "orchestra/testbench": "^6.2",
        "phpunit/phpunit": "^9.4",
        "illuminate/routing": "^8.7",
        "illuminate/http": "^8.7",
        "illuminate/view": "^8.7",
        "vlucas/phpdotenv": "^5.2"
    }
}
